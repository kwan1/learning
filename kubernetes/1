apiVersion: v1
kind: Pod
metadata:
  labels:
    run: app-server
  name: app-server
  namespace: secure-app
spec:
  containers:
    - image: nginx:alpine
    name: app-server
    resources: {}
    env:
      - name: DB_PASSWORD
        valueFrom:
          secretKeyRef:
            name: db-secret
            key: password
      - name: APP_ENV
        valueFrom:
          configMapKeyRef:
            name: app-config
            key: environment
        value: "environment"
  dnsPolicy: ClusterFirst
  restartPolicy: Always
status: {}
